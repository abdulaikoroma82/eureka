# Example Streamlit secrets configuration for XLSForm Studio
#
# For local development:
# 1. Copy this file to .streamlit/secrets.toml (already in .gitignore)
# 2. Fill in your actual API keys
# 3. Streamlit will automatically load these when running locally
#
# For hosted deployments (Hugging Face Spaces, Render, Railway, etc.):
# Set environment variables via the platform's Settings or Secrets panel instead.
# Most platforms use environment variables, not secrets.toml files.

# Optional: DeepSeek API key for AI-assisted features
# Get a key from: https://platform.deepseek.com/
# Without this, XLSForm Studio runs in fully offline, deterministic mode
DEEPSEEK_API_KEY = "sk-your-deepseek-api-key-here"
